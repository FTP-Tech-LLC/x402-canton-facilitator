{
  "name": "@ftptech/x402-canton-facilitator",
  "private": true,
  "version": "0.0.9",
  "description": "x402 facilitator for Canton Network — /verify and /settle compliant with the x402 spec",
  "license": "Apache-2.0",
  "author": "FTP team",
  "homepage": "https://github.com/sunstrike228/canton-x402/tree/main/packages/facilitator#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/sunstrike228/canton-x402.git",
    "directory": "packages/facilitator"
  },
  "bugs": {
    "url": "https://github.com/sunstrike228/canton-x402/issues"
  },
  "keywords": [
    "x402",
    "canton",
    "canton-network",
    "facilitator",
    "payment",
    "fastify"
  ],
  "type": "module",
  "main": "./dist/server.js",
  "exports": {
    ".": "./dist/server.js"
  },
  "bin": {
    "canton-x402-facilitator": "./dist/cli.js"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE",
    "Dockerfile",
    "docker-compose.yml",
    "docker-compose.production.yml"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json && chmod +x dist/cli.js",
    "start": "node dist/server.js",
    "dev": "tsx watch src/server.ts",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "vitest run",
    "lint": "eslint src --max-warnings 0"
  },
  "dependencies": {
    "@ftptech/x402-canton-core": "workspace:*",
    "@ftptech/x402-canton-ledger": "workspace:*",
    "fastify": "^5.1.0",
    "pg": "^8.21.0",
    "pino": "^9.5.0",
    "prom-client": "^15.1.3",
    "undici": "^7.1.0"
  },
  "devDependencies": {
    "@types/pg": "^8.20.0",
    "tsx": "^4.19.2"
  }
}
